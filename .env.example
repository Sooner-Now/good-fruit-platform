# Good Fruit Platform environment template
# Copy these into Vercel Project Settings -> Environment Variables.

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# OpenAI / Seedling advocate
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.2

# Stripe billing + identity
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_BUSINESS_PRICE_ID=
STRIPE_IDENTITY_VERIFICATION_TEMPLATE_ID=

# Email
RESEND_API_KEY=
EMAIL_FROM=Good Fruit <hello@goodfruit.local>

# Maps
MAPBOX_ACCESS_TOKEN=
GOOGLE_MAPS_API_KEY=

# App
GOOD_FRUIT_SITE_URL=https://good-fruit-platform.vercel.app
GOOD_FRUIT_ADMIN_EMAIL=
